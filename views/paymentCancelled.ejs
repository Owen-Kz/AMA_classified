<!-- views/paymentCancelled.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Payment Cancelled - Amaslink</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .fade-in-up {
            animation: fadeInUp 0.6s ease-out forwards;
        }
        .delay-1 {
            animation-delay: 0.2s;
            opacity: 0;
        }
        .delay-2 {
            animation-delay: 0.4s;
            opacity: 0;
        }
        .delay-3 {
            animation-delay: 0.6s;
            opacity: 0;
        }
    </style>
</head>
<body class="bg-gradient-to-br from-orange-50 via-white to-red-50 min-h-screen">
    <div class="container mx-auto px-4 py-8 md:py-16">
        <div class="max-w-2xl mx-auto">
            <!-- Cancelled Card -->
            <div class="bg-white rounded-2xl shadow-xl overflow-hidden fade-in-up">
                <!-- Header with gradient -->
                <div class="bg-gradient-to-r from-orange-500 to-red-600 px-6 py-8 text-center">
                    <div class="inline-flex items-center justify-center w-20 h-20 bg-white rounded-full mb-4">
                        <svg class="w-12 h-12 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </div>
                    <h1 class="text-2xl md:text-3xl font-bold text-white mb-2">Payment Cancelled</h1>
                    <p class="text-orange-100">
                        <%= paymentType === 'wallet' ? 'Your wallet top-up was cancelled' : 'Your transaction was not completed' %>
                    </p>
                </div>

                <!-- Content -->
                <div class="p-6 md:p-8">
                    <!-- Cancellation Message -->
                    <div class="text-center mb-8 fade-in-up delay-1">
                        <div class="bg-orange-50 border border-orange-200 rounded-lg p-4 mb-6">
                            <p class="text-orange-800 text-sm md:text-base">
                                Your payment was cancelled. No charges have been made to your account.
                                You can try again whenever you're ready.
                            </p>
                        </div>
                        
                        <% if (paymentType === 'listing') { %>
                            <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
                                <div class="flex items-start gap-3">
                                    <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                    <p class="text-blue-800 text-sm">
                                        <strong>Your listing is saved as a draft.</strong> You can complete the payment later
                                        from your dashboard to publish your listing.
                                    </p>
                                </div>
                            </div>
                        <% } %>
                    </div>

                    <!-- Transaction Details (if available) -->
                    <% if (transactionId || listingId) { %>
                    <div class="bg-gray-50 rounded-xl p-6 mb-8 fade-in-up delay-2">
                        <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
                            <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                            </svg>
                            Transaction Details
                        </h3>
                        <div class="space-y-3">
                            <% if (transactionId) { %>
                            <div class="flex justify-between items-center py-2 border-b border-gray-200">
                                <span class="text-gray-600">Transaction ID:</span>
                                <span class="font-mono text-sm text-gray-900"><%= transactionId %></span>
                            </div>
                            <% } %>
                            <% if (listingId) { %>
                            <div class="flex justify-between items-center py-2 border-b border-gray-200">
                                <span class="text-gray-600">Listing ID:</span>
                                <span class="font-mono text-sm text-gray-900"><%= listingId %></span>
                            </div>
                            <% } %>
                            <% if (title) { %>
                            <div class="flex justify-between items-center py-2 border-b border-gray-200">
                                <span class="text-gray-600">Title:</span>
                                <span class="font-medium text-gray-900"><%= title %></span>
                            </div>
                            <% } %>
                            <div class="flex justify-between items-center py-2">
                                <span class="text-gray-600">Amount:</span>
                                <span class="font-bold text-gray-900">$<%= amount %></span>
                            </div>
                        </div>
                    </div>
                    <% } %>

                    <!-- Action Buttons based on payment type -->
                    <div class="flex flex-col sm:flex-row gap-4 fade-in-up delay-3">
                        <% if (paymentType === 'wallet') { %>
                            <a href="https://amaslink.com/top-up" class="flex-1 text-center bg-gradient-to-r from-orange-500 to-red-600 text-white font-semibold py-3 px-6 rounded-xl hover:from-orange-600 hover:to-red-700 transition-all duration-200 shadow-md hover:shadow-lg">
                                Try Again
                            </a>
                            <a href="https://amaslink.com/wallet" class="flex-1 text-center bg-white border-2 border-gray-300 text-gray-700 font-semibold py-3 px-6 rounded-xl hover:bg-gray-50 hover:border-gray-400 transition-all duration-200">
                                Go to Wallet
                            </a>
                        <% } else if (paymentType === 'listing') { %>
                            <a href="https://amaslink.com/create-ad" class="flex-1 text-center bg-gradient-to-r from-orange-500 to-red-600 text-white font-semibold py-3 px-6 rounded-xl hover:from-orange-600 hover:to-red-700 transition-all duration-200 shadow-md hover:shadow-lg">
                                Try Again
                            </a>
                            <a href="https://amaslink.com/dashboard" class="flex-1 text-center bg-white border-2 border-gray-300 text-gray-700 font-semibold py-3 px-6 rounded-xl hover:bg-gray-50 hover:border-gray-400 transition-all duration-200">
                                Go to Dashboard
                            </a>
                        <% } else { %>
                            <a href="javascript:history.back()" class="flex-1 text-center bg-gradient-to-r from-orange-500 to-red-600 text-white font-semibold py-3 px-6 rounded-xl hover:from-orange-600 hover:to-red-700 transition-all duration-200 shadow-md hover:shadow-lg">
                                Try Again
                            </a>
                            <a href="https://amaslink.com/" class="flex-1 text-center bg-white border-2 border-gray-300 text-gray-700 font-semibold py-3 px-6 rounded-xl hover:bg-gray-50 hover:border-gray-400 transition-all duration-200">
                                Return Home
                            </a>
                        <% } %>
                    </div>

                    <!-- Additional Options -->
                    <div class="mt-8 pt-6 border-t border-gray-200 text-center fade-in-up delay-3">
                        <div class="space-y-2">
                            <p class="text-sm text-gray-500">
                                Having trouble? You can also:
                            </p>
                            <div class="flex flex-col sm:flex-row gap-3 justify-center">
                                <a href="https://amaslink.com/support" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-orange-600 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636L9.172 14.828M15 5h4v4M5 15h4v4M5 5h4v4M15 15h4v4"></path>
                                    </svg>
                                    Contact Support
                                </a>
                                <span class="hidden sm:inline text-gray-300">|</span>
                                <a href="https://amaslink.com/payment-methods" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-orange-600 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path>
                                    </svg>
                                    View Payment Methods
                                </a>
                            </div>
                        </div>
                        <p class="text-xs text-gray-400 mt-4">
                            Need immediate assistance? Call us at +1 (555) 123-4567
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Prevent accidental closure
        window.addEventListener('beforeunload', function(e) {
            e.preventDefault();
            e.returnValue = '';
        });
    </script>
</body>
</html>
