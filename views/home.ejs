<script>
    // Original JavaScript with Tailwind classes applied dynamically
    window.addEventListener('scroll', function() {
        const navbar = document.querySelector('.navbar');
        const topBar = document.querySelector('.topSection');
        if (window.scrollY > 50) {
            // Optional: Add shadow when scrolled
            navbar?.classList.add('shadow-lg');
            topBar?.classList.add('shadow-md');
        } else {
            navbar?.classList.remove('shadow-lg');
            topBar?.classList.remove('shadow-md');
        }
    });

    const navbarContainer = document.querySelectorAll(".navbarContainer");
    const topBarContainer = document.getElementById("topBarContainer");

    async function ProfileData() {
        return fetch(`/profile/details/informative`, {})
            .then(res => res.json())
            .then(data => {
                if (data.userDetails) {
                    return data.userDetails;
                } else {
                    return null;
                }
            });
    }

    const userLogged = await ProfileData();
    let isLoggedINProfile = "";

    if (userLogged && userLogged.id && userLogged.id != null && userLogged.id !== "" && userLogged.id != "2209102") {
        isLoggedINProfile = ` 
            <ul class="flex items-center space-x-4 text-sm">
                <li><a href="/dashboard" class="text-white hover:text-gray-200 transition">Welcome Back, <b class="font-semibold">${userLogged.u_name}</b></a></li>
                <li><a href="/announcements" class="text-white hover:text-gray-200 transition"><i class="bi bi-bell mr-1"></i><span class="hidden sm:inline">Announcements</span></a></li>
                <li><a href="/messages" class="text-white hover:text-gray-200 transition"><i class="bi bi-chat-right mr-1"></i><span class="hidden sm:inline">Messages</span></a></li>
                <li><a href="/mylistings" class="text-white hover:text-gray-200 transition"><i class="bi bi-list-columns-reverse mr-1"></i><span class="hidden sm:inline">Listings</span></a></li>
            </ul>`;
    } else {
        isLoggedINProfile = `    
            <ul class="flex items-center space-x-4 text-sm">
                <li><a href="/login" class="text-white hover:text-gray-200 transition">Login</a></li>
                <li><b><a href="/register" class="text-white hover:text-gray-200 transition font-semibold">Register</a></b></li>
            </ul>`;
    }

    // Update top bar with user info
    if (topBarContainer) {
        const topBarLeft = topBarContainer.querySelector('.topBarLeft ul');
        if (topBarLeft) {
            topBarLeft.outerHTML = isLoggedINProfile;
        }
    }

    // Update mobile user section
    const mobileUserSection = document.querySelector('.mobile-user-section');
    if (mobileUserSection) {
        if (userLogged && userLogged.id) {
            mobileUserSection.innerHTML = `
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 bg-[#b70000] rounded-full flex items-center justify-center text-white font-bold">
                        ${userLogged.u_name?.charAt(0).toUpperCase() || 'U'}
                    </div>
                    <div>
                        <p class="font-medium text-gray-800">${userLogged.u_name}</p>
                        <div class="flex space-x-2 mt-1">
                            <a href="/dashboard" class="text-xs text-[#b70000] hover:underline">Dashboard</a>
                            <a href="/logout" class="text-xs text-gray-500 hover:underline">Logout</a>
                        </div>
                    </div>
                </div>
            `;
        } else {
            mobileUserSection.innerHTML = `
                <div class="flex space-x-2">
                    <a href="/login" class="flex-1 text-center py-2 border border-[#b70000] text-[#b70000] rounded-lg hover:bg-red-50 transition">Login</a>
                    <a href="/register" class="flex-1 text-center py-2 bg-[#b70000] text-white rounded-lg hover:bg-[#9a0000] transition">Register</a>
                </div>
            `;
        }
    }

    // Mobile menu toggle
    document.addEventListener('DOMContentLoaded', function() {
        const mobileNavToggle = document.querySelector('.mobileNav');
        const containerForNav = document.querySelector('.containerForNav');
        const closeMobileNav = document.querySelector('.close-mobile-nav');
        
        if (mobileNavToggle && containerForNav) {
            mobileNavToggle.addEventListener('click', function() {
                containerForNav.classList.remove('translate-x-full');
            });
            
            if (closeMobileNav) {
                closeMobileNav.addEventListener('click', function() {
                    containerForNav.classList.add('translate-x-full');
                });
            }
        }

        // Mobile dropdown toggle
        const mobileDropdownToggle = document.querySelector('.mobile-dropdown-toggle');
        const mobileDropdownMenu = document.querySelector('.mobile-dropdown-menu');
        
        if (mobileDropdownToggle && mobileDropdownMenu) {
            mobileDropdownToggle.addEventListener('click', function() {
                mobileDropdownMenu.classList.toggle('hidden');
                const icon = this.querySelector('i');
                if (icon) {
                    icon.classList.toggle('bi-chevron-down');
                    icon.classList.toggle('bi-chevron-up');
                }
            });
        }
    });

    // Set active link based on current URL
    setTimeout(() => {
        const currentPath = window.location.pathname;
        const navLinks = document.querySelectorAll('.navigationLink a, .mobile-dropdown-menu a');
        
        navLinks.forEach(link => {
            const href = link.getAttribute('href');
            if (href && href !== '#' && currentPath.includes(href) && href !== '/') {
                link.classList.add('text-[#b70000]', 'font-semibold');
                if (link.closest('.navigationLink')) {
                    link.classList.add('border-b-2', 'border-[#b70000]');
                }
            } else if (href === '/' && currentPath === '/') {
                link.classList.add('text-[#b70000]', 'font-semibold');
                if (link.closest('.navigationLink')) {
                    link.classList.add('border-b-2', 'border-[#b70000]');
                }
            }
        });
    }, 100);
</script>

