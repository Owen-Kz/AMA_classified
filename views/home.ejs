    <!-- Listings Script -->
    <script>
        const staticAdvertsContainer = document.getElementById("staticAdvertContainer");
        const SLideShowAdvertsContainer = document.getElementById("slideAdvertContainer");
        const listingsContainer = document.getElementById("listingsContainer");
        const paginationContainer = document.getElementById("pagination");
        const listingsBottomContainer = document.getElementById("listingsBottomContainer");
        const ListingsTopContainer = document.getElementById("listingsTopContainer");
        const maxLength = 50;
        let ExchangeRate = 1;
        let Currency = "$";

        // Initialize slides
        SLideShowAdvertsContainer.innerHTML += `
            <a href="#">
                <div class="slide slide-four active" style="background-image: url(/uploads/AMAS.png);"></div>
            </a>`;

        // Static Adverts
        fetch(`/staticAdverts`, {
            method: "POST",
            header: {
                "Content-type": "application/JSON"
            }
        }).then(res => res.json())
            .then(data => {
                if (data && data.success) {
                    const staticAdverts = data.adverts;
                    if (staticAdverts) {
                        const advert = staticAdverts;
                        fetch(`/details/brand/${advert.title}/${advert.item_id}`, {
                            method: "GET"
                        }).then(res => res.json())
                            .then(async (data) => {
                                if (data.success) {
                                    const prodFiles = data.productFiles;
                                    let ImageContainer = "";
                                    if (prodFiles.length > 0) {
                                        const file = prodFiles[0];
                                        if ((file.file_type === "image_file" || file.file_type === "") && file.file_status === "old_submission") {
                                            ImageContainer = `<img src="/uploads/${file.file_url}" alt="${advert.title}" class="w-full h-auto rounded-lg"/>`;
                                        } else if ((file.file_type === "image_file" || file.file_type === "") && file.file_status === "new_submission") {
                                            ImageContainer = `<a href="/brand/${advert.title}/${advert.item_id}"><img src="${file.file_url}" alt="${advert.title}" class="w-full h-auto rounded-lg"/></a>`;
                                        }
                                    } else {
                                        ImageContainer = `<a href="/brand/${advert.title}/${advert.item_id}"><img src="/uploads/AMAS.png" alt="${advert.title}" class="w-full h-auto rounded-lg"/></a>`;
                                    }
                                    staticAdvertsContainer.innerHTML += ImageContainer;
                                }
                            });
                    }
                } else {
                    staticAdvertsContainer.innerHTML += `<a href="/adintro"><video class="w-full rounded-lg" autoplay muted loop>
                        <source src="https://res.cloudinary.com/dswliutlf/video/upload/v1729831711/t2xel3qhfui3oncuv5qo.mp4" type="video/mp4">
                    </video></a>`;
                }
            });

        // Slide Show Adverts
        fetch(`/SlideShowAdverts`, {
            method: "GET",
        }).then(res => res.json())
            .then(async data => {
                if (data && data.success) {
                    const SLideShowAdverts = data.adverts;
                    if (SLideShowAdverts.length > 0) {
                        for (let i = 0; i < SLideShowAdverts.length; i++) {
                            const advert = SLideShowAdverts[i];
                            await fetch(`/details/brand/${advert.title}/${advert.item_id}`, {
                                method: "GET"
                            }).then(res => res.json())
                                .then(async (data) => {
                                    if (data.success) {
                                        const prodFiles = data.productFiles;
                                        if (prodFiles.length > 0) {
                                            for (let b = 0; b < prodFiles.length; b++) {
                                                const file = prodFiles[b];
                                                if ((file.file_type === "image_file" || file.file_type === "") && file.file_status === "new_submission") {
                                                    SLideShowAdvertsContainer.innerHTML += `<a href="/brand/${advert.title}/${advert.item_id}">
                                                        <div class="slide" style="background-image: url('${file.file_url}');"></div>
                                                    </a>`;
                                                }
                                            }
                                        }
                                    }
                                });
                        }
                        // Initialize first slide as active
                        const slides = document.querySelectorAll('.ads-slide .slide');
                        if (slides.length > 0) {
                            slides[0].classList.add('active');
                        }
                    }
                }
            });

        // Views Count Function
        async function GetViewsCount(id) {
            return fetch(`/countViews/${id}`, {
                method: "GET"
            }).then(res => res.json())
                .then(data => {
                    if (data.success) {
                        return data.viewsCount;
                    } else {
                        return 0;
                    }
                });
        }

        // Product Files Function
        async function GetProductFiles(productId) {
            return fetch(`/listingFiles/${productId}`, {
                method: "GET"
            }).then(res => res.json())
                .then(data => {
                    if (data && data.success) {
                        return data.productFiles;
                    } else {
                        return [];
                    }
                });
        }

        // Loading State
        const demoData = `<div class="product_item loadingItem">
            <div class="image_container bg-gray-200"></div>
            <div class="p-4">
                <div class="h-4 bg-gray-200 rounded mb-2"></div>
                <div class="h-4 bg-gray-200 rounded w-2/3"></div>
            </div>
        </div>`;

        // New Page Function
        function NewPage(page) {
            if (listingsContainer) {
                for (let i = 0; i < 40; i++) {
                    listingsContainer.innerHTML += demoData;
                }
            }
            if (listingsBottomContainer) {
                for (let i = 0; i < 20; i++) {
                    listingsBottomContainer.innerHTML += demoData;
                }
            }
            if (ListingsTopContainer) {
                for (let i = 0; i < 20; i++) {
                    ListingsTopContainer.innerHTML += demoData;
                }
            }

            fetch(`/listings?page=${page}`, {
                method: "POST"
            }).then(res => res.json())
                .then(async (data) => {
                    if (data.success) {
                        const ListingsList = data.listings;

                        // Top Listings
                        if (ListingsTopContainer && ListingsList.length > 0) {
                            ListingsTopContainer.innerHTML = "";
                            let ItemLimit = Math.min(ListingsList.length, 10);
                            for (let i = 0; i < ItemLimit; i++) {
                                let country = ListingsList[i].country || "N/A";
                                let ItemPrice = ListingsList[i].price ? `${Currency} ${new Number(ListingsList[i].price * ExchangeRate).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : "";
                                let imageLink = "/uploads/AMAS.png";

                                const imagesArray = await GetProductFiles(ListingsList[i].id);
                                if (imagesArray.length > 0) {
                                    if (imagesArray[0].file_url && imagesArray[0].file_status === "old_submission") {
                                        imageLink = `/uploads/${imagesArray[0].file_url}`;
                                    } else if (imagesArray[0].file_url && imagesArray[0].file_status === "new_submission") {
                                        imageLink = imagesArray[0].file_url;
                                    }
                                }

                                ListingsTopContainer.innerHTML += `
                                    <a href="/l/${ListingsList[i].id}">
                                        <div class="product_item">
                                            <div class="image_container" style="background-image:url(${imageLink});">
                                                <img class="productImage" src="${imageLink}" alt="Product image">
                                            </div>
                                            <div class="actions">
                                                <div class="viewsCount">
                                                    <i class="bi bi-eye"></i>
                                                    <span>${await GetViewsCount(ListingsList[i].id)}</span>
                                                </div>
                                                <div class="save_item">
                                                    <form class="bookMarkItem">
                                                        <input type="hidden" name="itemID" value="${ListingsList[i].id}">
                                                        <button class="focus:outline-none">
                                                            <i class="bi bi-heart-fill"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                            <div class="product_info">
                                                <div class="product_name text-[#b70000]">${ItemPrice}</div>
                                                <div class="product_name limited-text">${ListingsList[i].title}</div>
                                                <div class="location"><i class="bi bi-map-fill mr-1"></i>${country}</div>
                                            </div>
                                        </div>
                                    </a>`;
                            }
                        }

                        // Bottom Listings
                        if (listingsBottomContainer && ListingsList.length > 10) {
                            listingsBottomContainer.innerHTML = "";
                            for (let i = 10; i < Math.min(20, ListingsList.length); i++) {
                                let country = ListingsList[i].country || "N/A";
                                let ItemPrice = ListingsList[i].price ? `${Currency} ${new Number(ListingsList[i].price * ExchangeRate).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : "";
                                let imageLink = "/uploads/AMAS.png";

                                const imagesArray = await GetProductFiles(ListingsList[i].id);
                                if (imagesArray.length > 0) {
                                    if (imagesArray[0].file_url && imagesArray[0].file_status === "old_submission") {
                                        imageLink = `/uploads/${imagesArray[0].file_url}`;
                                    } else if (imagesArray[0].file_url && imagesArray[0].file_status === "new_submission") {
                                        imageLink = imagesArray[0].file_url;
                                    }
                                }

                                listingsBottomContainer.innerHTML += `
                                    <a href="/l/${ListingsList[i].id}">
                                        <div class="product_item">
                                            <div class="image_container" style="background-image:url(${imageLink});">
                                                <img class="productImage" src="${imageLink}" alt="Product image">
                                            </div>
                                            <div class="actions">
                                                <div class="viewsCount">
                                                    <i class="bi bi-eye"></i>
                                                    <span>${await GetViewsCount(ListingsList[i].id)}</span>
                                                </div>
                                                <div class="save_item">
                                                    <form class="bookMarkItem">
                                                        <input type="hidden" name="itemID" value="${ListingsList[i].id}">
                                                        <button class="focus:outline-none">
                                                            <i class="bi bi-heart-fill"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                            <div class="product_info">
                                                <div class="product_name text-[#b70000]">${ItemPrice}</div>
                                                <div class="product_name limited-text">${ListingsList[i].title}</div>
                                                <div class="location"><i class="bi bi-map-fill mr-1"></i>${country}</div>
                                            </div>
                                        </div>
                                    </a>`;
                            }
                        }

                        // Bookmark Forms
                        const bookMarkForms = document.getElementsByClassName("bookMarkItem");
                        for (let k = 0; k < bookMarkForms.length; k++) {
                            bookMarkForms[k].addEventListener("submit", function (e) {
                                e.preventDefault();
                                const inputField = bookMarkForms[k].querySelector('input[name="itemID"]');
                                fetch(`/bookMarkItem`, {
                                    method: "POST",
                                    body: JSON.stringify({ itemID: inputField.value }),
                                    headers: { 'Content-Type': 'application/JSON' },
                                }).then(res => res.json())
                                    .then(data => {
                                        if (data.success) {
                                            console.log("Bookmarked successfully");
                                        } else {
                                            console.log(data.error);
                                        }
                                    });
                            });
                        }
                    }
                });
        }

        // URL Parameter Function
        function GetParameters(href) {
            const url = new URL(href);
            return new URLSearchParams(url.search);
        }

        // Initial Load
        const page = GetParameters(window.location.href).get("page");
        NewPage(page && page > 0 ? page : 1);

        // Categories
        const categoriesContainer = document.getElementById("productCategory");
        fetch(`/allCategories`, {
            method: "POST",
            body: JSON.stringify({ email: "amaslink@gmail.com" }),
            headers: { "Content-type": "application/JSON" }
        }).then(res => res.json())
            .then(data => {
                if (data.success) {
                    const Cats = data.categories;
                    categoriesContainer.innerHTML = `<a href="/adIntro">
                        <li class="bg-[#b70000] text-white hover:scale-105 transition">
                            <div class="icon_container"><i class="bi bi-link-45deg text-white"></i></div>
                            <div class="text_container">Post Ad</div>
                        </li></a>`;
                    for (let i = 0; i < Cats.length; i++) {
                        const category = Cats[i];
                        categoriesContainer.innerHTML += `<a href="/cat?c=${category.category_name}">
                            <li class="hover:scale-105 transition">
                                <div class="icon_container"><i>${category.icon}</i></div>
                                <div class="text_container">${category.category_name}</div>
                            </li></a>`;
                    }
                }
            });

        // Full Page Ad
        const fullpageAd = document.querySelectorAll(".fullpageAd");
        const innerFullPage = document.getElementById("innerFullPage");
        fullpageAd.forEach(advertContainer => {
            advertContainer.style.display = "none";
        });

        fetch(`/fullpageAd`)
            .then(res => res.json())
            .then(data => {
                try {
                    if (data.success && data.fullpageAd.length > 0 && data.fullpageAd[0].status === "approved") {
                        fullpageAd.forEach(advertContainer => {
                            advertContainer.style.display = "flex";
                        });
                        innerFullPage.innerHTML = `<img src="${data.fullpageAd[0].file_url}" alt="Full Page Advert" class="rounded-lg shadow-2xl"/>`;
                    }
                } catch (error) {
                    console.error(error);
                }
            });
    </script>
</body>

</html>