    <style>
        :root {
            --AmasLinkColor: #b70000;
        }

        /* Custom animations */
        @keyframes fade-in-right {
            from {
                opacity: 0;
                transform: translateX(30px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @keyframes fade-in-bottom {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes reveal-text {
            0% {
                clip-path: inset(0 100% 0 0);
            }
            100% {
                clip-path: inset(0 0 0 0);
            }
        }

        .fade-in-right {
            animation: fade-in-right 1s ease forwards;
        }

        .fade-in-bottom {
            animation: fade-in-bottom 1s ease forwards;
        }

        .reveal-text {
            animation: reveal-text 1.5s ease forwards;
        }

        /* Slider styles */
        .main-slider {
            position: relative;
            height: 100vh;
            overflow: hidden;
        }

        .single-slide {
            position: relative;
            height: 100vh;
            width: 100%;
        }

        .bg-img {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }

        .bg-img::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0.2) 100%);
        }

        .slider-content-wrap {
            position: relative;
            height: 100%;
            z-index: 2;
        }

        .slider-content {
            color: white;
        }

        .slide-caption.medium {
            font-size: 1.5rem;
            margin-bottom: 1rem;
            opacity: 0;
        }

        .slide-caption.big {
            font-size: 4rem;
            font-weight: 700;
            line-height: 1.2;
            margin-bottom: 1rem;
            opacity: 0;
        }

        .slide-caption.small {
            font-size: 1.1rem;
            max-width: 600px;
            margin-bottom: 2rem;
            opacity: 0;
        }

        .slide-btn-group {
            opacity: 0;
        }

        .slide-btn {
            display: inline-block;
            padding: 1rem 2.5rem;
            background: var(--AmasLinkColor);
            color: white;
            text-decoration: none;
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .slide-btn:hover {
            background: #9a0000;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(183, 0, 0, 0.3);
        }

        /* Category styles */
        .category_container {
            width: 100%;
            overflow-x: auto;
            padding: 1rem 0;
        }

        .categoriesList {
            display: flex;
            gap: 1rem;
            padding: 0.5rem;
            min-width: max-content;
        }

        .categoriesList li {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            width: 120px;
            height: 120px;
            background: white;
            border-radius: 1rem;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .categoriesList li:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
        }

        .categoriesList .icon_container {
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }

        .categoriesList .text_container {
            font-size: 0.9rem;
            font-weight: 500;
            text-align: center;
            padding: 0 0.5rem;
        }

        /* Product card styles */
        .product_item {
            background: white;
            border-radius: 1rem;
            overflow: hidden;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
            position: relative;
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .product_item:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15);
        }

        .image_container {
            position: relative;
            width: 100%;
            padding-top: 100%;
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }

        .productImage {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .actions {
            position: absolute;
            top: 0.5rem;
            right: 0.5rem;
            left: 0.5rem;
            display: flex;
            justify-content: space-between;
            z-index: 2;
        }

        .viewsCount, .save_item {
            background: rgba(255, 255, 255, 0.9);
            padding: 0.25rem 0.75rem;
            border-radius: 2rem;
            font-size: 0.875rem;
            display: flex;
            align-items: center;
            gap: 0.25rem;
            backdrop-filter: blur(5px);
        }

        .save_item button {
            padding: 0;
            background: transparent;
            border: none;
            cursor: pointer;
        }

        .save_item .bi-heart-fill {
            color: var(--AmasLinkColor);
            font-size: 1.1rem;
        }

        .product_info {
            padding: 1rem;
            flex: 1;
        }

        .product_name {
            font-weight: 600;
            margin-bottom: 0.5rem;
            line-height: 1.4;
        }

        .product_name:first-child {
            color: var(--AmasLinkColor);
            font-size: 1.1rem;
        }

        .location {
            display: flex;
            align-items: center;
            gap: 0.25rem;
            font-size: 0.875rem;
            color: #6b7280;
        }

        .limited-text {
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
        }

        /* Loading state */
        .loadingItem {
            background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
            background-size: 200% 100%;
            animation: loading 1.5s infinite;
        }

        @keyframes loading {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        /* Ads slider */
        .ads-slide {
            position: relative;
            height: 400px;
            overflow: hidden;
            border-radius: 1rem;
        }

        .ads-slide .slide {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-size: cover;
            background-position: center;
            opacity: 0;
            transition: opacity 0.5s ease;
        }

        .ads-slide .slide.active {
            opacity: 1;
        }

        .ads-slide .arrow {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            width: 40px;
            height: 40px;
            background: rgba(255, 255, 255, 0.9);
            border: none;
            border-radius: 50%;
            cursor: pointer;
            z-index: 10;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }

        .ads-slide .arrow:hover {
            background: white;
            transform: translateY(-50%) scale(1.1);
        }

        .ads-slide .left-arrow {
            left: 1rem;
        }

        .ads-slide .right-arrow {
            right: 1rem;
        }

        /* Static ad */
        .static-ad {
            width: 100%;
            min-height: 200px;
            border-radius: 1rem;
            overflow: hidden;
            margin-top: 2rem;
        }

        .static-ad img, .static-ad video {
            width: 100%;
            height: auto;
            object-fit: cover;
        }

        /* Full page ad */
        .fullpageAd {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 9999;
            display: none;
            align-items: center;
            justify-content: center;
            background: rgba(0, 0, 0, 0.8);
        }

        .fullpageAd.inner {
            max-width: 90%;
            max-height: 90%;
        }

        .fullpageAd.inner img {
            width: 100%;
            height: auto;
            max-height: 90vh;
            object-fit: contain;
            border-radius: 1rem;
        }

        /* Pagination */
        .pagination {
            display: flex;
            gap: 0.5rem;
            list-style: none;
            padding: 0;
        }

        .pagination_item {
            display: inline-block;
        }

        .pagination_item li {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            background: white;
            border-radius: 0.5rem;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .pagination_item:hover li {
            background: var(--AmasLinkColor);
            color: white;
        }

        .pagination_item.active li {
            background: var(--AmasLinkColor);
            color: white;
        }

        /* Responsive adjustments */
        @media (max-width: 768px) {
            .slide-caption.medium {
                font-size: 1.2rem;
            }
            
            .slide-caption.big {
                font-size: 2.5rem;
            }
            
            .slide-caption.small {
                font-size: 1rem;
            }
            
            .categoriesList li {
                width: 100px;
                height: 100px;
            }
            
            .products_list {
                grid-template-columns: repeat(2, 1fr) !important;
            }
        }

        @media (max-width: 480px) {
            .slide-caption.big {
                font-size: 2rem;
            }
            
            .products_list {
                grid-template-columns: 1fr !important;
            }
        }
    </style>
</head>

